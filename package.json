{
  "name": "aecfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "biome check --write",
    "lint:ci": "biome ci",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "pnpm -F db migrate",
    "db:generate": "pnpm -F db generate",
    "db:push": "pnpm -F db push",
    "db:studio": "pnpm -F db studio",
    "bootstrap": "tsx scripts/bootstrap.ts"
  },
  "devDependencies": {
    "@aecfolio/db": "workspace:*",
    "@aecfolio/shared": "workspace:*",
    "@biomejs/biome": "^2.4.16",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.9.17"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  }
}
